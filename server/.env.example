# Copy this file to ".env" and adjust for your environment.
# Values shown are the development defaults applied when a variable is unset.

# HTTP port the API listens on.
PORT=8080

# Path to the SQLite database file (created automatically).
DATABASE_PATH=lua_academy.db

# Secret used to sign JWTs. MUST be a long random string in production.
JWT_SECRET=dev-insecure-secret-change-me

# Session lifetime, in hours.
JWT_TTL_HOURS=72

# Origin allowed to call the API (the frontend dev server).
ALLOWED_ORIGIN=http://localhost:5173

# Public URL of the frontend, used to build Stripe redirect URLs.
FRONTEND_URL=http://localhost:5173

# Stripe keys (Phase 7). Leave empty to disable payments locally.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe recurring price for the monthly "Complet" subscription (price_...).
STRIPE_SUBSCRIPTION_PRICE_ID=

# SMTP (notifications e-mail). Leave SMTP_HOST empty to disable e-mail (in-app only).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Lua Academy <no-reply@lua-academy.local>
